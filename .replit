modules = ["nodejs-20"]
[agent]
expertMode = true
integrations = ["javascript_object_storage:2.0.0", "javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN BROWSER=none npx expo start --tunnel --web --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3002

[objectStorage]
defaultBucketID = "replit-objstore-c12a5da0-505b-4dfa-9acc-b4d9ea85d53b"

[userenv]

[userenv.shared]
PRIVATE_OBJECT_DIR = "/replit-objstore-c12a5da0-505b-4dfa-9acc-b4d9ea85d53b/.private"
PUBLIC_OBJECT_SEARCH_PATHS = "/replit-objstore-c12a5da0-505b-4dfa-9acc-b4d9ea85d53b/public"
