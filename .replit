modules = ["nodejs-20"]
[agent]
expertMode = true
integrations = ["javascript_object_storage:2.0.0", "javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN BROWSER=none npx expo start --tunnel --web --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[objectStorage]
defaultBucketID = "replit-objstore-5246cf14-2e3a-465f-814f-b583d98a36ca"
